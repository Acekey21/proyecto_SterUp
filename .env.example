# ============================================================================
# CONFIGURACIÓN DE EMAIL CON PHPMAILER
# ============================================================================

# Modo de email: 'demo' (guardar en logs) o 'smtp' (enviar real)
EMAIL_MODE=demo

# Información del remitente
MAIL_FROM_ADDRESS=noreply@stepup.local
MAIL_FROM_NAME=StepUp
MAIL_ADMIN_EMAIL=admin@stepup.local

# ============================================================================
# CONFIGURACIÓN SMTP (para EMAIL_MODE=smtp)
# ============================================================================

# Servidor SMTP (Gmail, SendGrid, Outlook, etc)
SMTP_HOST=smtp.gmail.com

# Puerto SMTP
# - Gmail: 587 (TLS) o 465 (SSL)
# - SendGrid: 587
# - Outlook: 587
SMTP_PORT=587

# Usuario SMTP (email o usuario)
# Para Gmail: tu_email@gmail.com
# Para SendGrid: apikey
SMTP_USER=

# Contraseña o API Key
# Para Gmail: CONTRASEÑA DE APLICACIÓN (no tu contraseña normal)
# Para SendGrid: Tu API Key (comienza con SG.)
SMTP_PASS=

# Protocolo de seguridad
# - tls (recomendado para puerto 587)
# - ssl (para puerto 465)
SMTP_SECURE=tls
